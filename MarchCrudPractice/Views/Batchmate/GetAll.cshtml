@model IEnumerable<MarchCrudPractice.Models.Batchmates>

@{
    ViewData["Title"] = "Batchmates List";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Batchmates List</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            + Add New
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-0">

            <table class="table table-hover text-center mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Name)</th>
                        <th>@Html.DisplayNameFor(model => model.Age)</th>
                        <th>@Html.DisplayNameFor(model => model.Course)</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.Age</td>
                            <td>
                                <span class="badge bg-info text-dark px-3 py-2">
                                    @item.Course
                                </span>
                            </td>
                            <td>
                                <a asp-action="Update" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-warning me-2">
                                    Edit
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Are you sure you want to delete this record?');">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>